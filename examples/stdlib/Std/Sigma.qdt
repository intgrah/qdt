import Std.Eq

structure Sigma.{u, v} (α : Type u) (β : α → Type v) : Type (max u v) where
  (fst : α)
  (snd : β fst)

def Sigma.eta.{u, v} (α : Type u) (β : α → Type v) (p : Sigma.{u, v} α β) :
    Sigma.mk.{u, v} α β (Sigma.fst.{u, v} α β p) (Sigma.snd.{u, v} α β p) = p :=
  Eq.refl.{max u v} (Sigma.{u, v} α β) p
