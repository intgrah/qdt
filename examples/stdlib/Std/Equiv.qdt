import Std.Eq
import Std.Init

structure Equiv.{u, v} (α : Type u) (β : Type v) : Type (max u v) where
  (toFun : α → β)
  (invFun : β → α)
  (left_inv : comp invFun toFun = id)
  (right_inv : comp toFun invFun = id)

def Equiv.refl.{u} (α : Type u) : Equiv α α := Equiv.mk id id rfl rfl

axiom ua.{u} (α β : Type u) (e : Equiv α β) : α = β
