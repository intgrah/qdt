import Std.Eq

inductive Pathover.{u, v} (α : Type u) (P : α → Type v) (a : α) (b : P a) :
    (a' : α) → Eq α a a' → P a' → Type v where
  | idpo : Pathover α P a b a (Eq.refl α a) b

def Pathover.rfl.{u, v} (α : Type u) (P : α → Type v) (a : α) (b : P a) :
    Pathover α P a b a (Eq.refl α a) b :=
  Pathover.idpo _ _ _ _
