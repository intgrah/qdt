import Std.Bool
import Std.Eq
import Std.Quotient
import Std.Unit

def I.rel (a b : Bool) : Type := Unit

def I : Type := quotient Bool I.rel

def I.zero : I := quotient.class_of _ _ Bool.true

def I.one : I := quotient.class_of _ _ Bool.false

def I.seg : Eq I I.zero I.one := quotient.eq_of_rel Bool I.rel Bool.true Bool.false Unit.unit
