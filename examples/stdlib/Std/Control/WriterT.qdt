        (Monad.bind m inst P R x normal_r)
        (WriterT.bind_assoc_rhs ω m inst instW α β γ x f g)))

def WriterT.instMonad.{u, v} (ω : Type u) (m : Type u → Type v) (inst : Monad m) (instW : Monoid ω) : Monad (WriterT ω m) :=
  Monad.mk
    (WriterT ω m)
    (WriterT.pure ω m inst instW)
    (WriterT.bind ω m inst instW)
    (fun (α β : Type u) (a : α) (f : α → WriterT ω m β) =>
      WriterT.bind_pure_left ω m inst instW α β a f)
    (fun (α : Type u) (x : WriterT ω m α) => WriterT.bind_pure_right ω m inst instW α x)
    (fun (α β γ : Type u) (x : WriterT ω m α) (f : α → WriterT ω m β) (g : β → WriterT ω m γ) =>
      WriterT.bind_assoc ω m inst instW α β γ x f g)
