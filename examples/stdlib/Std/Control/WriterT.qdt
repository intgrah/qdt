                        (Monad.pure m inst R)
                        (Prod.mk
                          γ
                          ω
                          (Prod.fst γ ω s)
                          (Monoid.mul
                            ω
                            instW
                            (Monoid.mul ω instW (Prod.snd α ω p) (Prod.snd β ω q))
                            (Prod.snd γ ω s)))
                        (Prod.mk
                          γ
                          ω
                          (Prod.fst γ ω s)
                          (Monoid.mul
                            ω
                            instW
                            (Prod.snd α ω p)
                            (Monoid.mul ω instW (Prod.snd β ω q) (Prod.snd γ ω s))))
                        (congrArg
                          ω
                          R
                          (fun (w : ω) => Prod.mk γ ω (Prod.fst γ ω s) w)
                          (Monoid.mul
                            ω
                            instW
                            (Monoid.mul ω instW (Prod.snd α ω p) (Prod.snd β ω q))
                            (Prod.snd γ ω s))
                          (Monoid.mul
                            ω
                            instW
                            (Prod.snd α ω p)
                            (Monoid.mul ω instW (Prod.snd β ω q) (Prod.snd γ ω s)))
                          (Monoid.mul_assoc
