                        (Prod.snd γ ω s)))))
            (fun (q : Q) =>
              Monad.bind
                m
                inst
                R
                R
                (g (Prod.fst β ω q))
                (fun (s : R) =>
                  Monad.pure
                    m
                    inst
                    R
                    (Prod.mk
                      γ
                      ω
                      (Prod.fst γ ω s)
                      (Monoid.mul
                        ω
                        instW
                        (Prod.snd α ω p)
                        (Monoid.mul ω instW (Prod.snd β ω q) (Prod.snd γ ω s))))))
            (funext
              Q
              (fun (q : Q) => m R)
              (fun (q : Q) =>
                Monad.bind
                  m
                  inst
                  R
                  R
                  (g (Prod.fst β ω q))
                  (fun (s : R) =>
                    Monad.pure
                      m
                      inst
                      R
                      (Prod.mk
                        γ
                        ω
                        (Prod.fst γ ω s)
                        (Monoid.mul
                          ω
                          instW
                          (Monoid.mul ω instW (Prod.snd α ω p) (Prod.snd β ω q))
                          (Prod.snd γ ω s)))))
              (fun (q : Q) =>
                Monad.bind
                  m
