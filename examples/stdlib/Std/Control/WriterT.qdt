                        (Prod.fst γ ω s)
                        (Monoid.mul
                          ω
                          instW
                          (Monoid.mul ω instW (Prod.snd α ω p) (Prod.snd β ω q))
                          (Prod.snd γ ω s))))
                  (fun (s : R) =>
                    Monad.pure
