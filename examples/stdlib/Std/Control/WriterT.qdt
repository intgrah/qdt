def WriterT.bind_assoc.{u, v} (ω : Type u) (m : Type u → Type v) (inst : Monad m) (instW : Monoid ω) (α β γ : Type u) (x : WriterT ω m α) (f : α → WriterT ω m β) (g : β → WriterT ω m γ) : Eq (m (Prod γ ω)) (WriterT.bind ω m inst instW β γ (WriterT.bind ω m inst instW α β x f) g) (WriterT.bind ω m inst instW α γ x (fun (a : α) => WriterT.bind ω m inst instW β γ (f a) g)) :=
  let P : Type u := Prod α ω;
  let Q : Type u := Prod β ω;
  let R : Type u := Prod γ ω;
  let normal_l : P → m R :=
    fun (p : P) =>
      Monad.bind
        m
        inst
        Q
        R
        (f (Prod.fst α ω p))
        (fun (q : Q) =>
          Monad.bind
            m
            inst
            R
            R
            (g (Prod.fst β ω q))
            (fun (s : R) =>
              Monad.pure
                m
                inst
                R
                (Prod.mk
                  γ
                  ω
                  (Prod.fst γ ω s)
                  (Monoid.mul
                    ω
                    instW
                    (Monoid.mul ω instW (Prod.snd α ω p) (Prod.snd β ω q))
                    (Prod.snd γ ω s)))));
  let normal_r : P → m R :=
    fun (p : P) =>
      Monad.bind
        m
        inst
        Q
        R
        (f (Prod.fst α ω p))
        (fun (q : Q) =>
          Monad.bind
            m
            inst
            R
            R
            (g (Prod.fst β ω q))
            (fun (s : R) =>
              Monad.pure
                m
                inst
                R
                (Prod.mk
                  γ
                  ω
                  (Prod.fst γ ω s)
                  (Monoid.mul
                    ω
                    instW
                    (Prod.snd α ω p)
                    (Monoid.mul ω instW (Prod.snd β ω q) (Prod.snd γ ω s))))));
  let assoc_step : Monad.bind m inst P R x normal_l = Monad.bind m inst P R x normal_r :=
    congrArg
      (P → m R)
      (m R)
      (fun (k : P → m R) => Monad.bind m inst P R x k)
      normal_l
      normal_r
      (funext
        P
        (fun (p : P) => m R)
        normal_l
        normal_r
        (fun (p : P) =>
          congrArg
            (Q → m R)
            (m R)
            (fun (k : Q → m R) => Monad.bind m inst Q R (f (Prod.fst α ω p)) k)
            (fun (q : Q) =>
              Monad.bind
                m
                inst
                R
                R
                (g (Prod.fst β ω q))
                (fun (s : R) =>
