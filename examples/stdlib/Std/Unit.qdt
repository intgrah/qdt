import Std.Eq

inductive Unit.{u} : Type u where
  | unit

def Unit.eta.{u} (t : Unit.{u}) : Unit.unit.{u} = t :=
  Eq.refl.{u} Unit.{u} Unit.unit.{u}

def Unit.ext.{u} (a b : Unit.{u}) : a = b :=
  Eq.trans.{u} Unit.{u} a Unit.unit.{u} b (Eq.symm.{u} Unit.{u} Unit.unit.{u} a (Unit.eta.{u} a)) (Unit.eta.{u} b)
