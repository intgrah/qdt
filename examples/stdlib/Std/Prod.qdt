import Std.Eq

structure Prod.{u, v} (α : Type u) (β : Type v) : Type (max u v) where
  (fst : α)
  (snd : β)

def Prod.swap.{u, v} {α : Type u} {β : Type v} (p : Prod α β) : Prod β α :=
  Prod.mk (Prod.snd p) (Prod.fst p)

def Prod.eta.{u, v}
    {α : Type u} {β : Type v} (p : Prod α β) :
    Prod.mk (Prod.fst p) (Prod.snd p) = p :=
  rfl
