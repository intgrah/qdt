inductive Bool where
  | true
  | false

def Bool.ite.{u} (α : Type u) (b : Bool) (t f : α) :=
  Bool.rec.{u} (fun _ => α) t f b

def Bool.dite.{u} (motive : Bool → Type u) (b : Bool) (t : motive Bool.true) (f : motive Bool.false) : motive b :=
  Bool.rec.{u} motive t f b

def Bool.not (b : Bool) :=
  Bool.ite.{0} Bool Bool.false Bool.true b

def Bool.and (a b : Bool) :=
  Bool.ite.{0} Bool Bool.false b a

def Bool.or (a b : Bool) :=
  Bool.ite.{0} Bool b Bool.true a
