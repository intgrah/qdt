inductive Bool where
  | true
  | false

def Bool.ite.{u} (A : Type u) (b : Bool) (t f : A) :=
  Bool.rec.{u} (fun _ => A) t f b

def Bool.dite.{u} (A : Bool → Type u) (b : Bool) (t : A Bool.true) (f : A Bool.false) : A b :=
  Bool.rec.{u} A t f b

def Bool.not (b : Bool) :=
  Bool.ite.{0} Bool Bool.false Bool.true b

def Bool.and (a b : Bool) :=
  Bool.ite.{0} Bool Bool.false b a

def Bool.or (a b : Bool) :=
  Bool.ite.{0} Bool b Bool.true a
