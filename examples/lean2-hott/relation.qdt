l_4} A c) (eq.refl.{max l_4 l_5} (tc.{l_4, l_5} A R a_2 b) a_3) (eq.refl.{max l_4 l_5} (tc.{l_4, l_5} A R b c) a_4)))) v2 H12

def tc.below.{l, l_4, l_5} : (A : Type l_4) → (R : A → A → Type l_5) → ((a : A) → (a_1 : A) → tc.{l_4, l_5} A R a a_1 → Type l) → (a : A) → (a_1 : A) → tc.{l_4, l_5} A R a a_1 → Type (max (1) l) :=
