 (tc.{l_4, l_5} A R b_1 c_1) (eq.rec.{max l_4 l_5, l_4} A c (fun (c_2 : A) => fun (e_3_1 : eq.{l_4} A c c_2) => tc.{l_4, l_5} A R b_1 c_2) (eq.rec.{max l_4 l_5, l_4} A b (fun (b_2 : A) => fun (e_2_1 : eq.{l_4} A b b_2) => tc.{l_4, l_5} A R b_2 c) a_4 b_1 e_2) c_1 e_3) a_7 → P) → lift.{l, max l_4 l_5} P))

