import logic

def reflexive.{l_2, l_3} : (B : Type l_2) → (B → B → Type l_3) → Type (max l_2 l_3) :=
  fun (B : Type l_2) => fun (R : B → B → Type l_3) => (x : B) → R x x

def symmetric.{l_2, l_3} : (B : Type l_2) → (B → B → Type l_3) → Type (max l_2 l_3) :=
  fun (B : Type l_2) => fun (R : B → B → Type l_3) => (x : B) → (y : B) → R x y → R y x

def transitive.{l_2, l_3} : (B : Type l_2) → (B → B → Type l_3) → Type (max l_2 l_3) :=
  fun (B : Type l_2) => fun (R : B → B → Type l_3) => (x : B) → (y : B) → (z : B) → R x y → R y z → R x z

def irreflexive.{l_2, l_3} : (B : Type l_2) → (B → B → Type l_3) → Type (max l_2 l_3) :=
  fun (B : Type l_2) => fun (R : B → B → Type l_3) => (x : B) → not.{l_3} (R x x)

def anti_symmetric.{l_2, l_3} : (B : Type l_2) → (B → B → Type l_3) → Type (max l_3 l_2) :=
  fun (B : Type l_2) => fun (R : B → B → Type l_3) => (x : B) → (y : B) → R x y → R y x → eq.{l_2} B x y

def empty_relation.{l_1} : (A : Type l_1) → A → A → Type 0 :=
  fun (A : Type l_1) => fun (a₁ : A) => fun (a₂ : A) => empty

def subrelation.{l_2, l_4, l_5} : (B : Type l_2) → (B → B → Type l_4) → (B → B → Type l_5) → Type (max l_2 (max l_4 l_5)) :=
  fun (B : Type l_2) => fun (Q : B → B → Type l_4) => fun (R : B → B → Type l_5) => (x : B) → (y : B) → Q x y → R x y

def inv_image.{l_1, l_2, l_3} : (A : Type l_1) → (B : Type l_2) → (B → B → Type l_3) → (A → B) → A → A → Type l_3 :=
  fun (A : Type l_1) => fun (B : Type l_2) => fun (R : B → B → Type l_3) => fun (f : A → B) => fun (a₁ : A) => fun (a₂ : A) => R (f a₁) (f a₂)

def inv_image.trans.{l_1, l_2, l_3} : (A : Type l_1) → (B : Type l_2) → (R : B → B → Type l_3) → (f : A → B) → transitive.{l_2, l_3} B R → transitive.{l_1, l_3} A (inv_image.{l_1, l_2, l_3} A B R f) :=
  fun (A : Type l_1) => fun (B : Type l_2) => fun (R : B → B → Type l_3) => fun (f : A → B) => fun (H : transitive.{l_2, l_3} B R) => fun (a₁ : A) => fun (a₂ : A) => fun (a₃ : A) => H (f a₁) (f a₂) (f a₃)

def inv_image.irreflexive.{l_1, l_2, l_3} : (A : Type l_1) → (B : Type l_2) → (R : B → B → Type l_3) → (f : A → B) → irreflexive.{l_2, l_3} B R → irreflexive.{l_1, l_3} A (inv_image.{l_1, l_2, l_3} A B R f) :=
  fun (A : Type l_1) => fun (B : Type l_2) => fun (R : B → B → Type l_3) => fun (f : A → B) => fun (H : irreflexive.{l_2, l_3} B R) => fun (a : A) => H (f a)

inductive tc.{l_4, l_5} (A : Type l_4) (R : A → A → Type l_5) : A → A → Type (max l_4 l_5) where
  | base : (a : A) → (b : A) → R a b → tc.{l_4, l_5} A R a b
  | trans : (a : A) → (b : A) → (c : A) → tc.{l_4, l_5} A R a b → tc.{l_4, l_5} A R b c → tc.{l_4, l_5} A R a c

def tc.rec_on.{l, l_4, l_5} : (A : Type l_4) → (R : A → A → Type l_5) → (C : (a : A) → (a_1 : A) → tc.{l_4, l_5} A R a a_1 → Type l) → (a : A) → (a_1 : A) → (n : tc.{l_4, l_5} A R a a_1) → ((a_2 : A) → (b : A) → (a_3 : R a_2 b) → C a_2 b (tc.base.{l_4, l_5} A R a_2 b a_3)) → ((a_2 : A) → (b : A) → (c : A) → (a_3 : tc.{l_4, l_5} A R a_2 b) → (a_4 : tc.{l_4, l_5} A R b c) → C a_2 b a_3 → C b c a_4 → C a_2 c (tc.trans.{l_4, l_5} A R a_2 b c a_3 a_4)) → C a a_1 n :=
  fun (A : Type l_4) => fun (R : A → A → Type l_5) => fun (C : (a : A) → (a_1 : A) → tc.{l_4, l_5} A R a a_1 → Type l) => fun (a : A) => fun (a_1 : A) => fun (n : tc.{l_4, l_5} A R a a_1) => fun (e_1 : (a_2 : A) → (b : A) → (a_3 : R a_2 b) → C a_2 b (tc.base.{l_4, l_5} A R a_2 b a_3)) => fun (e_2 : (a_2 : A) → (b : A) → (c : A) → (a_3 : tc.{l_4, l_5} A R a_2 b) → (a_4 : tc.{l_4, l_5} A R b c) → C a_2 b a_3 → C b c a_4 → C a_2 c (tc.trans.{l_4, l_5} A R a_2 b c a_3 a_4)) => tc.rec.{l, l_4, l_5} A R C e_1 e_2 a a_1 n

def tc.cases_on.{l, l_4, l_5} : (A : Type l_4) → (R : A → A → Type l_5) → (C : (a : A) → (a_1 : A) → tc.{l_4, l_5} A R a a_1 → Type l) → (a : A) → (a_1 : A) → (n : tc.{l_4, l_5} A R a a_1) → ((a_2 : A) → (b : A) → (a_3 : R a_2 b) → C a_2 b (tc.base.{l_4, l_5} A R a_2 b a_3)) → ((a_2 : A) → (b : A) → (c : A) → (a_3 : tc.{l_4, l_5} A R a_2 b) → (a_4 : tc.{l_4, l_5} A R b c) → C a_2 c (tc.trans.{l_4, l_5} A R a_2 b c a_3 a_4)) → C a a_1 n :=
  fun (A : Type l_4) => fun (R : A → A → Type l_5) => fun (C : (a : A) → (a_1 : A) → tc.{l_4, l_5} A R a a_1 → Type l) => fun (a : A) => fun (a_1 : A) => fun (n : tc.{l_4, l_5} A R a a_1) => fun (e_1 : (a_2 : A) → (b : A) → (a_3 : R a_2 b) → C a_2 b (tc.base.{l_4, l_5} A R a_2 b a_3)) => fun (e_2 : (a_2 : A) → (b : A) → (c : A) → (a_3 : tc.{l_4, l_5} A R a_2 b) → (a_4 : tc.{l_4, l_5} A R b c) → C a_2 c (tc.trans.{l_4, l_5} A R a_2 b c a_3 a_4)) => tc.rec.{l, l_4, l_5} A R C (fun (a_2 : A) => fun (b : A) => fun (a_3 : R a_2 b) => e_1 a_2 b a_3) (fun (a_2 : A) => fun (b : A) => fun (c : A) => fun (a_3 : tc.{l_4, l_5} A R a_2 b) => fun (a_4 : tc.{l_4, l_5} A R b c) => fun (v_0 : C a_2 b a_3) => fun (v_1 : C b c a_4) => e_2 a_2 b c a_3 a_4) a a_1 n

