+            unsigned lv = export_expr(let_value(e));
+            unsigned lb = export_expr(let_body(e));
+            i = m_expr2idx.size();
+            m_out << i << " #EZ " << ln << " " << lt << " " << lv << " " << lb << "\n";
             break;
+        }
         case expr_kind::Lambda:
             i  = export_binding(e, "#EL");
             break;
@@ -182,7 +373,9 @@ class exporter {
