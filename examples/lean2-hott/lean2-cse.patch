 namespace lean {
+/** \brief Common-subexpression elimination: introduce kernel let-bindings for
+    repeated shareable subexpressions. Operates on closed declaration bodies. */
+class cse_pass {
+    type_checker                 m_tc;
+    expr_bi_struct_map<unsigned> m_count;
+    expr_bi_struct_map<unsigned> m_size;
+
+    unsigned size_of(expr const & e) {
+        auto it = m_size.find(e);
+        if (it != m_size.end()) return it->second;
+        unsigned s = 1;
+        switch (e.kind()) {
+        case expr_kind::Var: case expr_kind::Sort: case expr_kind::Constant:
+        case expr_kind::Meta: case expr_kind::Local:
+            s = 1; break;
+        case expr_kind::App:
+            s = 1 + size_of(app_fn(e)) + size_of(app_arg(e)); break;
+        case expr_kind::Lambda: case expr_kind::Pi:
+            s = 1 + size_of(binding_domain(e)) + size_of(binding_body(e)); break;
+        case expr_kind::Let:
+            s = 1 + size_of(let_type(e)) + size_of(let_value(e)) + size_of(let_body(e)); break;
+        case expr_kind::Macro:
+            // unfold_all_macros has run before CSE; macros should not appear.
+            s = 1; break;
+        }
+        m_size.insert(mk_pair(e, s));
+        return s;
+    }
+
+    void count_visit(expr const & e) {
+        auto it = m_count.find(e);
+        if (it != m_count.end()) {
+            it->second++;
+            return;
+        }
+        m_count.insert(mk_pair(e, 1u));
+        switch (e.kind()) {
+        case expr_kind::Var: case expr_kind::Sort: case expr_kind::Constant:
+        case expr_kind::Meta: case expr_kind::Local:
+            break;
+        case expr_kind::App:
+            count_visit(app_fn(e));
+            count_visit(app_arg(e));
+            break;
+        case expr_kind::Lambda: case expr_kind::Pi:
+            count_visit(binding_domain(e));
+            // do NOT recurse into binding_body: different de Bruijn frame
+            break;
+        case expr_kind::Let:
+            count_visit(let_type(e));
+            count_visit(let_value(e));
+            // do NOT recurse into let_body: different de Bruijn frame
+            break;
+        case expr_kind::Macro:
+            // unfold_all_macros has run before CSE; macros should not appear.
+            break;
+        }
+    }
+
+    /** \brief Do CSE on \c e treating it as living at binder-depth \c depth.
+        Shareable subterms with free_var_range <= depth are wrapped in let-bindings
+        at the top of \c e. */
+    expr do_cse_at(expr const & e, unsigned depth, buffer<expr> const & locals) {
+        static const unsigned MIN_COUNT = 4;
+        static const unsigned MIN_SIZE  = 8;
+        m_count.clear();
+        count_visit(e);
+        buffer<expr> shareable;
+        for (auto const & p : m_count) {
+            expr const & sub = p.first;
+            unsigned ct = p.second;
+            if (ct < MIN_COUNT) continue;
+            if (get_free_var_range(sub) > depth) continue;
+            if (size_of(sub) < MIN_SIZE) continue;
+            switch (sub.kind()) {
+            case expr_kind::Var: case expr_kind::Sort: case expr_kind::Constant:
+            case expr_kind::Meta: case expr_kind::Local:
+                continue;
+            default: break;
+            }
+            shareable.push_back(sub);
+        }
+        std::sort(shareable.begin(), shareable.end(), [&](expr const & a, expr const & b) {
+                return size_of(a) > size_of(b);
+            });
+        expr_bi_struct_map<expr> sub_to_local;
+        buffer<pair<expr, expr>> lets;
+        for (expr const & sub : shareable) {
+            expr open_sub = sub;
+            if (get_free_var_range(sub) > 0)
+                open_sub = instantiate_rev(sub, locals.size(), locals.data());
+            expr ty;
+            try {
+                ty = m_tc.infer(open_sub).first;
+            } catch (exception &) {
+                continue;
+            }
+            if (get_free_var_range(sub) > 0)
+                ty = abstract_locals(ty, locals.size(), locals.data());
+            if (get_free_var_range(ty) > depth) continue;
+            expr l = mk_local(mk_fresh_name(), name("_share"), ty, binder_info());
+            sub_to_local.insert(mk_pair(sub, l));
+            lets.push_back(mk_pair(l, sub));
+        }
+        if (lets.empty()) return e;
+        // Only replace at offset 0 (current scope): hash-consed cells at deeper
+        // de Bruijn frames have different meaning and must not be substituted.
+        auto do_replace = [&](expr const & x) -> expr {
+            return replace(x, [&](expr const & m, unsigned offset) -> optional<expr> {
+                    if (offset != 0) return none_expr();
+                    auto it = sub_to_local.find(m);
+                    if (it != sub_to_local.end()) return some_expr(it->second);
+                    return none_expr();
+                });
+        };
+        expr result = do_replace(e);
+        for (auto & p : lets) {
+            p.second = replace(p.second, [&](expr const & m, unsigned offset) -> optional<expr> {
+                    if (offset != 0) return none_expr();
+                    auto it = sub_to_local.find(m);
+                    if (it != sub_to_local.end() && !is_eqp(it->second, p.first))
+                        return some_expr(it->second);
+                    return none_expr();
+                });
+        }
+        for (auto & p : lets) {
+            expr lifted = lift_free_vars(result, 1);
+            expr abs_body = abstract_local(lifted, p.first);
+            result = mk_let(local_pp_name(p.first), mlocal_type(p.first), p.second, abs_body);
+        }
+        return result;
+    }
+
+    /** \brief Walk the term recursively, applying CSE at each binder body. */
+    expr cse_recursive(expr const & e, unsigned depth, buffer<expr> & locals) {
+        switch (e.kind()) {
+        case expr_kind::Var: case expr_kind::Sort: case expr_kind::Constant:
+        case expr_kind::Meta: case expr_kind::Local:
+        case expr_kind::Macro:
+            return e;
+        case expr_kind::App:
+            return mk_app(cse_recursive(app_fn(e), depth, locals),
+                          cse_recursive(app_arg(e), depth, locals));
+        case expr_kind::Lambda: case expr_kind::Pi: {
+            expr d = cse_recursive(binding_domain(e), depth, locals);
+            // Open d with the locals already in scope so the synthetic local's
+            // stored type contains no raw de Bruijn vars (only free locals).
+            expr d_open = locals.empty() ? d : instantiate_rev(d, locals.size(), locals.data());
+            expr l = mk_local(mk_fresh_name(), binding_name(e), d_open, binding_info(e));
+            locals.push_back(l);
+            expr b = cse_recursive(binding_body(e), depth + 1, locals);
+            b = do_cse_at(b, depth + 1, locals);
+            locals.pop_back();
+            return update_binding(e, d, b);
+        }
+        case expr_kind::Let: {
+            expr t = cse_recursive(let_type(e), depth, locals);
+            expr v = cse_recursive(let_value(e), depth, locals);
+            expr t_open = locals.empty() ? t : instantiate_rev(t, locals.size(), locals.data());
+            expr l = mk_local(mk_fresh_name(), let_name(e), t_open, binder_info());
+            locals.push_back(l);
+            expr b = cse_recursive(let_body(e), depth + 1, locals);
+            b = do_cse_at(b, depth + 1, locals);
+            locals.pop_back();
+            return update_let(e, t, v, b);
+        }
+        }
+        return e;
+    }
+public:
+    cse_pass(environment const & env) : m_tc(env) {}
+
+    expr apply(expr const & e) {
+        buffer<expr> locals;
+        expr result = cse_recursive(e, 0, locals);
+        return do_cse_at(result, 0, locals);
+    }
+};
+
 template<typename T>
 using level_map = typename std::unordered_map<level, T, level_hash, level_eq>;
 
