def naive_funext.{l_1, l_2} : Type (max (l_2 + 1) (max (max l_2 (l_1 + 1)) (max l_2 l_1))) :=
  (A : Type l_2) → (P : A → Type l_1) → (f : (x : A) → P x) → (g : (x : A) → P x) → eq.homotopy.{l_2, l_1} A P f g → eq.{max l_2 l_1} ((x : A) → P x) f g

def weak_funext.{l_1, l_2} : Type (max (l_1 + 1) (max (max l_1 (l_2 + 1)) (max (max l_1 l_2) (max l_2 l_1)))) :=
