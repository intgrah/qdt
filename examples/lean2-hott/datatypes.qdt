inductive poly_unit.{l} : Type l where
  | star : poly_unit.{l}

def poly_unit.rec_on.{l_1, l} : (C : poly_unit.{l} → Type l_1) → (n : poly_unit.{l}) → C poly_unit.star.{l} → C n :=
  fun (C : poly_unit.{l} → Type l_1) => fun (n : poly_unit.{l}) => fun (e_1 : C poly_unit.star.{l}) => poly_unit.rec.{l_1, l} C e_1 n

def poly_unit.cases_on.{l_1, l} : (C : poly_unit.{l} → Type l_1) → (n : poly_unit.{l}) → C poly_unit.star.{l} → C n :=
  fun (C : poly_unit.{l} → Type l_1) => fun (n : poly_unit.{l}) => fun (e_1 : C poly_unit.star.{l}) => poly_unit.rec.{l_1, l} C e_1 n

inductive unit : Type 0 where
  | star : unit

def unit.rec_on.{l} : (C : unit → Type l) → (n : unit) → C unit.star → C n :=
  fun (C : unit → Type l) => fun (n : unit) => fun (e_1 : C unit.star) => unit.rec.{l} C e_1 n

def unit.cases_on.{l} : (C : unit → Type l) → (n : unit) → C unit.star → C n :=
  fun (C : unit → Type l) => fun (n : unit) => fun (e_1 : C unit.star) => unit.rec.{l} C e_1 n

inductive empty : Type 0 where

