def prod.no_confusion_type.{l, l_1, l_2} : (A : Type l_1) → (B : Type l_2) → Type l → prod.{l_1, l_2} A B → prod.{l_1, l_2} A B → Type (max l (max l_1 l_2)) :=
  fun (A : Type l_1) => fun (B : Type l_2) => fun (P : Type l) => fun (v1 : prod.{l_1, l_2} A B) => fun (v2 : prod.{l_1, l_2} A B) => prod.cases_on.{max l (max l_1 l_2) + 1, l_1, l_2} A B (fun (v1_1 : prod.{l_1, l_2} A B) => Type (max l (max l_1 l_2))) v1 (fun (a : A) => fun (a_1 : B) => prod.cases_on.{max l (max l_1 l_2) + 1, l_1, l_2} A B (fun (v1_1 : prod.{l_1, l_2} A B) => Type (max l (max l_1 l_2))) v2 (fun (a_2 : A) => fun (a_3 : B) => (eq.{l_1} A a a_2 → eq.{l_2} B a_1 a_3 → P) → lift.{l, max l_1 l_2} P))

def prod.no_confusion.{l, l_1, l_2} : (A : Type l_1) → (B : Type l_2) → (P : Type l) → (v1 : prod.{l_1, l_2} A B) → (v2 : prod.{l_1, l_2} A B) → eq.{max l_1 l_2} (prod.{l_1, l_2} A B) v1 v2 → prod.no_confusion_type.{l, l_1, l_2} A B P v1 v2 :=
  fun (A : Type l_1) => fun (B : Type l_2) => fun (P : Type l) => fun (v1 : prod.{l_1, l_2} A B) => fun (v2 : prod.{l_1, l_2} A B) => fun (H12 : eq.{max l_1 l_2} (prod.{l_1, l_2} A B) v1 v2) => eq.rec.{max l (max l_1 l_2), max l_1 l_2} (prod.{l_1, l_2} A B) v1 (fun (a : prod.{l_1, l_2} A B) => fun (H1a : eq.{max l_1 l_2} (prod.{l_1, l_2} A B) v1 a) => prod.no_confusion_type.{l, l_1, l_2} A B P v1 a) (prod.cases_on.{max l (max l_1 l_2), l_1, l_2} A B (fun (v1_1 : prod.{l_1, l_2} A B) => prod.no_confusion_type.{l, l_1, l_2} A B P v1_1 v1_1) v1 (fun (a : A) => fun (a_1 : B) => fun (a_2 : eq.{l_1} A a a → eq.{l_2} B a_1 a_1 → P) => lift.up.{l, max l_1 l_2} P (a_2 (eq.refl.{l_1} A a) (eq.refl.{l_2} B a_1)))) v2 H12

def prod.pr1.{l_1, l_2} : (A : Type l_1) → (B : Type l_2) → prod.{l_1, l_2} A B → A :=
  fun (A : Type l_1) => fun (B : Type l_2) => prod.rec.{l_1, l_1, l_2} A B (fun (n : prod.{l_1, l_2} A B) => A) (fun (a : A) => fun (b : B) => a)

def prod.pr2.{l_1, l_2} : (A : Type l_1) → (B : Type l_2) → prod.{l_1, l_2} A B → B :=
  fun (A : Type l_1) => fun (B : Type l_2) => prod.rec.{l_2, l_1, l_2} A B (fun (n : prod.{l_1, l_2} A B) => B) (fun (a : A) => fun (b : B) => b)

def prod.destruct.{l_1, l_2, l_3} : (A : Type l_1) → (B : Type l_2) → (C : prod.{l_1, l_2} A B → Type l_3) → (n : prod.{l_1, l_2} A B) → ((a : A) → (a_1 : B) → C (prod.mk.{l_1, l_2} A B a a_1)) → C n :=
  prod.cases_on.{l_3, l_1, l_2}

