  fun (A : Type l_1) => fun (B : Type l_2) => fun (C : prod.{l_1, l_2} A B → Type l) => fun (n : prod.{l_1, l_2} A B) => fun (e_1 : (a : A) → (a_1 : B) → C (prod.mk.{l_1, l_2} A B a a_1)) => prod.rec.{l, l_1, l_2} A B C e_1 n

