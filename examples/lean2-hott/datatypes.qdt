  fun (A : Type l₁) => fun (c : lift.{l₁, l₂} A) => lift.rec.{l₁, l₁, l₂} A (fun (c_1 : lift.{l₁, l₂} A) => A) (fun (down : A) => down) c

def lift.rec_on.{l, l₁, l₂} : (A : Type l₁) → (C : lift.{l₁, l₂} A → Type l) → (n : lift.{l₁, l₂} A) → ((down : A) → C (lift.up.{l₁, l₂} A down)) → C n :=
  fun (A : Type l₁) => fun (C : lift.{l₁, l₂} A → Type l) => fun (n : lift.{l₁, l₂} A) => fun (e_1 : (down : A) → C (lift.up.{l₁, l₂} A down)) => lift.rec.{l, l₁, l₂} A C e_1 n

