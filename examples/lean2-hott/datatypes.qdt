def option.rec_on.{l, l_1} : (A : Type l_1) → (C : option.{l_1} A → Type l) → (n : option.{l_1} A) → C (option.none.{l_1} A) → ((a : A) → C (option.some.{l_1} A a)) → C n :=
  fun (A : Type l_1) => fun (C : option.{l_1} A → Type l) => fun (n : option.{l_1} A) => fun (e_1 : C (option.none.{l_1} A)) => fun (e_2 : (a : A) → C (option.some.{l_1} A a)) => option.rec.{l, l_1} A C e_1 e_2 n

def option.cases_on.{l, l_1} : (A : Type l_1) → (C : option.{l_1} A → Type l) → (n : option.{l_1} A) → C (option.none.{l_1} A) → ((a : A) → C (option.some.{l_1} A a)) → C n :=
  fun (A : Type l_1) => fun (C : option.{l_1} A → Type l) => fun (n : option.{l_1} A) => fun (e_1 : C (option.none.{l_1} A)) => fun (e_2 : (a : A) → C (option.some.{l_1} A a)) => option.rec.{l, l_1} A C e_1 (fun (a : A) => e_2 a) n

def option.no_confusion_type.{l, l_1} : (A : Type l_1) → Type l → option.{l_1} A → option.{l_1} A → Type (max l l_1) :=
  fun (A : Type l_1) => fun (P : Type l) => fun (v1 : option.{l_1} A) => fun (v2 : option.{l_1} A) => option.cases_on.{max l l_1 + 1, l_1} A (fun (v1_1 : option.{l_1} A) => Type (max l l_1)) v1 (option.cases_on.{max l l_1 + 1, l_1} A (fun (v1_1 : option.{l_1} A) => Type (max l l_1)) v2 (P → lift.{l, l_1} P) (fun (a : A) => lift.{l, l_1} P)) (fun (a : A) => option.cases_on.{max l l_1 + 1, l_1} A (fun (v1_1 : option.{l_1} A) => Type (max l l_1)) v2 (lift.{l, l_1} P) (fun (a_1 : A) => (eq.{l_1} A a a_1 → P) → lift.{l, l_1} P))

def option.no_confusion.{l, l_1} : (A : Type l_1) → (P : Type l) → (v1 : option.{l_1} A) → (v2 : option.{l_1} A) → eq.{l_1} (option.{l_1} A) v1 v2 → option.no_confusion_type.{l, l_1} A P v1 v2 :=
  fun (A : Type l_1) => fun (P : Type l) => fun (v1 : option.{l_1} A) => fun (v2 : option.{l_1} A) => fun (H12 : eq.{l_1} (option.{l_1} A) v1 v2) => eq.rec.{max l l_1, l_1} (option.{l_1} A) v1 (fun (a : option.{l_1} A) => fun (H1a : eq.{l_1} (option.{l_1} A) v1 a) => option.no_confusion_type.{l, l_1} A P v1 a) (option.cases_on.{max l l_1, l_1} A (fun (v1_1 : option.{l_1} A) => option.no_confusion_type.{l, l_1} A P v1_1 v1_1) v1 (fun (a : P) => lift.up.{l, l_1} P a) (fun (a : A) => fun (a_1 : eq.{l_1} A a a → P) => lift.up.{l, l_1} P (a_1 (eq.refl.{l_1} A a)))) v2 H12

inductive nat : Type 0 where
  | zero : nat
  | succ : nat → nat

def nat.below.{l} : (nat → Type l) → nat → Type (max (1) l) :=
  fun (C : nat → Type l) => fun (n : nat) => nat.rec.{max (1) l + 1} (fun (n_1 : nat) => Type (max (1) l)) poly_unit.{max (1) l} (fun (a : nat) => fun (v_0 : Type (max (1) l)) => prod.{l, max (1) l} (C a) v_0) n

def nat.brec_on.{l} : (C : nat → Type l) → (n : nat) → ((n_1 : nat) → nat.below.{l} C n_1 → C n_1) → C n :=
  fun (C : nat → Type l) => fun (n : nat) => fun (F_1 : (n_1 : nat) → nat.below.{l} C n_1 → C n_1) => prod.pr1.{l, max (1) l} (C n) (nat.below.{l} C n) (nat.rec.{max (1) l} (fun (n_1 : nat) => prod.{l, max (1) l} (C n_1) (nat.below.{l} C n_1)) (prod.mk.{l, max (1) l} (C nat.zero) poly_unit.{max (1) l} (F_1 nat.zero poly_unit.star.{max (1) l}) poly_unit.star.{max (1) l}) (fun (a : nat) => fun (v_0 : prod.{l, max (1) l} (C a) (nat.below.{l} C a)) => prod.mk.{l, max (1) l} (C (nat.succ a)) (prod.{l, max (1) l} (C a) (nat.below.{l} C a)) (F_1 (nat.succ a) v_0) v_0) n)

