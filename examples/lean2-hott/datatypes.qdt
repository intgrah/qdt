  fun (A : Type l₁) => fun (C : lift.{l₁, l₂} A → Type l) => fun (n : lift.{l₁, l₂} A) => fun (e_1 : (down : A) → C (lift.up.{l₁, l₂} A down)) => lift.rec.{l, l₁, l₂} A C e_1 n

def lift.cases_on.{l, l₁, l₂} : (A : Type l₁) → (C : lift.{l₁, l₂} A → Type l) → (n : lift.{l₁, l₂} A) → ((down : A) → C (lift.up.{l₁, l₂} A down)) → C n :=
  fun (A : Type l₁) => fun (C : lift.{l₁, l₂} A → Type l) => fun (n : lift.{l₁, l₂} A) => fun (e_1 : (down : A) → C (lift.up.{l₁, l₂} A down)) => lift.rec.{l, l₁, l₂} A C e_1 n

def lift.no_confusion_type.{l, l₁, l₂} : (A : Type l₁) → Type l → lift.{l₁, l₂} A → lift.{l₁, l₂} A → Type (max l (max l₁ l₂)) :=
  fun (A : Type l₁) => fun (P : Type l) => fun (v1 : lift.{l₁, l₂} A) => fun (v2 : lift.{l₁, l₂} A) => lift.cases_on.{max l (max l₁ l₂) + 1, l₁, l₂} A (fun (v1_1 : lift.{l₁, l₂} A) => Type (max l (max l₁ l₂))) v1 (fun (down : A) => lift.cases_on.{max l (max l₁ l₂) + 1, l₁, l₂} A (fun (v1_1 : lift.{l₁, l₂} A) => Type (max l (max l₁ l₂))) v2 (fun (down_1 : A) => (eq.{l₁} A down down_1 → P) → lift.{l, max l₁ l₂} P))

def lift.no_confusion.{l, l₁, l₂} : (A : Type l₁) → (P : Type l) → (v1 : lift.{l₁, l₂} A) → (v2 : lift.{l₁, l₂} A) → eq.{max l₁ l₂} (lift.{l₁, l₂} A) v1 v2 → lift.no_confusion_type.{l, l₁, l₂} A P v1 v2 :=
  fun (A : Type l₁) => fun (P : Type l) => fun (v1 : lift.{l₁, l₂} A) => fun (v2 : lift.{l₁, l₂} A) => fun (H12 : eq.{max l₁ l₂} (lift.{l₁, l₂} A) v1 v2) => eq.rec.{max l (max l₁ l₂), max l₁ l₂} (lift.{l₁, l₂} A) v1 (fun (a : lift.{l₁, l₂} A) => fun (H1a : eq.{max l₁ l₂} (lift.{l₁, l₂} A) v1 a) => lift.no_confusion_type.{l, l₁, l₂} A P v1 a) (lift.cases_on.{max l (max l₁ l₂), l₁, l₂} A (fun (v1_1 : lift.{l₁, l₂} A) => lift.no_confusion_type.{l, l₁, l₂} A P v1_1 v1_1) v1 (fun (down : A) => fun (a : eq.{l₁} A down down → P) => lift.up.{l, max l₁ l₂} P (a (eq.refl.{l₁} A down)))) v2 H12

inductive prod.{l_1, l_2} (A : Type l_1) (B : Type l_2) : Type (max l_1 l_2) where
  | mk : A → B → prod.{l_1, l_2} A B

