  fun (C : empty → Type l) => fun (n : empty) => empty.rec.{l} C n

def empty.cases_on.{l} : (C : empty → Type l) → (n : empty) → C n :=
  fun (C : empty → Type l) => fun (n : empty) => empty.rec.{l} C n

inductive eq.{l} (A : Type l) (a : A) : A → Type l where
  | refl : eq.{l} A a a

def eq.rec_on.{l_1, l} : (A : Type l) → (a : A) → (C : (a_1 : A) → eq.{l} A a a_1 → Type l_1) → (a_1 : A) → (n : eq.{l} A a a_1) → C a (eq.refl.{l} A a) → C a_1 n :=
  fun (A : Type l) => fun (a : A) => fun (C : (a_1 : A) → eq.{l} A a a_1 → Type l_1) => fun (a_1 : A) => fun (n : eq.{l} A a a_1) => fun (e_1 : C a (eq.refl.{l} A a)) => eq.rec.{l_1, l} A a C e_1 a_1 n

