def prod_imp_iff.{l_5, l_6, l_7} : (a : Type l_5) → (b : Type l_6) → (c : Type l_7) → iff.{max l_7 (max l_5 l_6), max l_7 (max l_5 l_6)} (prod.{l_5, l_6} a b → c) (a → b → c) :=
