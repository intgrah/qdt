import types

def imp.{l_5, l_6} : Type l_5 → Type l_6 → Type (max l_5 l_6) :=
  fun (a : Type l_5) => fun (b : Type l_6) => a → b

def imp.id.{l_1} : (a : Type l_1) → a → a :=
  fun (a : Type l_1) => fun (H : a) => H

def imp.intro.{l_1, l_2} : (a : Type l_1) → (b : Type l_2) → a → b → a :=
  fun (a : Type l_1) => fun (b : Type l_2) => fun (H : a) => fun (H₂ : b) => H

def imp.mp.{l_1, l_2} : (a : Type l_1) → (b : Type l_2) → a → (a → b) → b :=
  fun (a : Type l_1) => fun (b : Type l_2) => fun (H : a) => fun (H₂ : a → b) => H₂ H

def imp.syl.{l_1, l_2, l_3} : (a : Type l_1) → (b : Type l_2) → (c : Type l_3) → (a → b) → (c → a) → c → b :=
  fun (a : Type l_1) => fun (b : Type l_2) => fun (c : Type l_3) => fun (H : a → b) => fun (H₂ : c → a) => fun (Hc : c) => H (H₂ Hc)

def imp.left.{l_1, l_2, l_3} : (a : Type l_1) → (b : Type l_2) → (c : Type l_3) → (a → b) → (b → c) → a → c :=
  fun (a : Type l_1) => fun (b : Type l_2) => fun (c : Type l_3) => fun (H : a → b) => fun (H₂ : b → c) => fun (Ha : a) => H₂ (H Ha)

def imp_unit.{l_5} : (a : Type l_5) → iff.{l_5, 0} (a → unit) unit :=
  fun (a : Type l_5) => iff_unit_intro.{l_5} (a → unit) (imp.intro.{0, l_5} unit a unit.star)

def unit_imp.{l_5} : (a : Type l_5) → iff.{l_5, l_5} (unit → a) a :=
  fun (a : Type l_5) => iff.intro.{l_5, l_5} (unit → a) a (fun (H : unit → a) => H unit.star) (imp.intro.{l_5, 0} a unit)

def imp_empty.{l_5} : (a : Type l_5) → iff.{l_5, l_5} (a → empty) (not.{l_5} a) :=
  fun (a : Type l_5) => iff.rfl.{l_5} (a → empty)

def empty_imp.{l_5} : (a : Type l_5) → iff.{l_5, 0} (empty → a) unit :=
  fun (a : Type l_5) => iff_unit_intro.{l_5} (empty → a) (empty.elim.{l_5} a)

def not.elim.{l_1, l_5} : (a : Type l_1) → (A : Type l_5) → not.{l_1} a → a → A :=
  fun (a : Type l_1) => fun (A : Type l_5) => fun (H1 : not.{l_1} a) => fun (H2 : a) => absurd.{l_1, l_5} a A H2 H1

def not.mto.{l_5, l_6} : (a : Type l_5) → (b : Type l_6) → (a → b) → not.{l_6} b → not.{l_5} a :=
  fun (a : Type l_5) => fun (b : Type l_6) => imp.left.{l_5, l_6, 0} a b empty

def not_imp_not_of_imp.{l_5, l_6} : (a : Type l_5) → (b : Type l_6) → (a → b) → not.{l_6} b → not.{l_5} a :=
  not.mto.{l_5, l_6}

def not_not_of_not_implies.{l_1, l_2} : (a : Type l_1) → (b : Type l_2) → not.{max l_1 l_2} (a → b) → not.{l_1} (not.{l_1} a) :=
  fun (a : Type l_1) => fun (b : Type l_2) => not.mto.{l_1, max l_1 l_2} (not.{l_1} a) (a → b) (not.elim.{l_1, l_2} a b)

def not_of_not_implies.{l_1, l_2} : (a : Type l_1) → (b : Type l_2) → not.{max l_1 l_2} (a → b) → not.{l_2} b :=
  fun (a : Type l_1) => fun (b : Type l_2) => not.mto.{l_2, max l_2 l_1} b (a → b) (imp.intro.{l_2, l_1} b a)

def not_not_em.{l_1} : (a : Type l_1) → not.{l_1} (not.{l_1} (sum.{l_1, l_1} a (not.{l_1} a))) :=
  fun (a : Type l_1) => fun (not_em : not.{l_1} (sum.{l_1, l_1} a (not.{l_1} a))) => not_em (sum.inr.{l_1, l_1} a (not.{l_1} a) (not.mto.{l_1, l_1} a (sum.{l_1, l_1} a (not.{l_1} a)) (sum.inl.{l_1, l_1} a (not.{l_1} a)) not_em))

def not_iff_not.{l_1, l_2} : (a : Type l_1) → (b : Type l_2) → iff.{l_1, l_2} a b → iff.{l_1, l_2} (not.{l_1} a) (not.{l_2} b) :=
  fun (a : Type l_1) => fun (b : Type l_2) => fun (H : iff.{l_1, l_2} a b) => iff.intro.{l_1, l_2} (not.{l_1} a) (not.{l_2} b) (not.mto.{l_2, l_1} b a (iff.mpr.{l_1, l_2} a b H)) (not.mto.{l_1, l_2} a b (iff.mp.{l_1, l_2} a b H))

def not_prod_of_not_left.{l_1, l_5} : (a : Type l_1) → (b : Type l_5) → not.{l_1} a → not.{max l_1 l_5} (prod.{l_1, l_5} a b) :=
  fun (a : Type l_1) => fun (b : Type l_5) => not.mto.{max l_1 l_5, l_1} (prod.{l_1, l_5} a b) a (prod.pr1.{l_1, l_5} a b)

