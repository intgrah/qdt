  fun (n : trunc_index) => fun (P : Type l) => fun (v1 : trunctype.{l_1} n) => fun (v2 : trunctype.{l_1} n) => fun (H12 : eq.{l_1 + 1} (trunctype.{l_1} n) v1 v2) => eq.rec.{max l (l_1 + 1), l_1 + 1} (trunctype.{l_1} n) v1 (fun (a : trunctype.{l_1} n) => fun (H1a : eq.{l_1 + 1} (trunctype.{l_1} n) v1 a) => trunctype.no_confusion_type.{l, l_1} n P v1 a) (trunctype.cases_on.{max l (l_1 + 1), l_1} n (fun (v1_1 : trunctype.{l_1} n) => trunctype.no_confusion_type.{l, l_1} n P v1_1 v1_1) v1 (fun (carrier : Type l_1) => fun (struct : is_trunc.{l_1} n carrier) => fun (a : (e_1 : eq.{l_1 + 1} Type l_1 carrier carrier) → eq.{l_1} (is_trunc.{l_1} n carrier) (eq.rec.{l_1, l_1 + 1} Type l_1 carrier (fun (carrier_1 : Type l_1) => fun (e_1_1 : eq.{l_1 + 1} Type l_1 carrier carrier_1) => is_trunc.{l_1} n carrier_1) struct carrier e_1) struct → P) => lift.up.{l, l_1 + 1} P (a (eq.refl.{l_1 + 1} Type l_1 carrier) (eq.refl.{l_1} (is_trunc.{l_1} n carrier) struct)))) v2 H12

def Prop.{l_1} : Type (l_1 + 1) :=
  trunctype.{l_1} (trunc_index.succ trunc_index.minus_two)

def Set.{l_1} : Type (l_1 + 1) :=
  trunctype.{l_1} (zero.{0} trunc_index has_zero_trunc_index)

def Prop.mk.{l_1} : (carrier : Type l_1) → is_trunc.{l_1} (trunc_index.succ trunc_index.minus_two) carrier → trunctype.{l_1} (trunc_index.succ trunc_index.minus_two) :=
  trunctype.mk.{l_1} (trunc_index.succ trunc_index.minus_two)

def Set.mk.{l_1} : (carrier : Type l_1) → is_trunc.{l_1} (trunc_index.succ (trunc_index.succ trunc_index.minus_two)) carrier → trunctype.{l_1} (trunc_index.succ (trunc_index.succ trunc_index.minus_two)) :=
  trunctype.mk.{l_1} (trunc_index.succ (trunc_index.succ trunc_index.minus_two))

def trunctype.mk'.{l_1} : (n : trunc_index) → (A : Type l_1) → is_trunc.{l_1} n A → trunctype.{l_1} n :=
  trunctype.mk.{l_1}

def is_trunc.tlift.{u, v} : (n : trunc_index) → trunctype.{u} n → trunctype.{max u v} n :=
  fun (n : trunc_index) => fun (A : trunctype.{u} n) => trunctype.mk.{max u v} n (lift.{u, max u v} (trunctype.carrier.{u} n A)) (is_trunc.is_trunc_lift.{u, max u v} (trunctype.carrier.{u} n A) n (trunctype.struct.{u} n A))

