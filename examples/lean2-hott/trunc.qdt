  fun (n : trunc_index) => fun (P : Type l) => fun (v1 : trunctype.{l_1} n) => fun (v2 : trunctype.{l_1} n) => trunctype.cases_on.{max l (l_1 + 1) + 1, l_1} n (fun (v1_1 : trunctype.{l_1} n) => Type (max l (l_1 + 1))) v1 (fun (carrier : Type l_1) => fun (struct : is_trunc.{l_1} n carrier) => trunctype.cases_on.{max l (l_1 + 1) + 1, l_1} n (fun (v1_1 : trunctype.{l_1} n) => Type (max l (l_1 + 1))) v2 (fun (carrier_1 : Type l_1) => fun (struct_1 : is_trunc.{l_1} n carrier_1) => ((e_1 : eq.{l_1 + 1} Type l_1 carrier carrier_1) → eq.{l_1} (is_trunc.{l_1} n carrier_1) (eq.rec.{l_1, l_1 + 1} Type l_1 carrier (fun (carrier_2 : Type l_1) => fun (e_1_1 : eq.{l_1 + 1} Type l_1 carrier carrier_2) => is_trunc.{l_1} n carrier_2) struct carrier_1 e_1) struct_1 → P) → lift.{l, l_1 + 1} P))

