inductive has_zero.{l_1} (A : Type l_1) : Type l_1 where
  | mk : A → has_zero.{l_1} A

def has_zero.zero.{l_1} : (A : Type l_1) → has_zero.{l_1} A → A :=
  fun (A : Type l_1) => fun (c : has_zero.{l_1} A) => has_zero.rec.{l_1, l_1} A (fun (c_1 : has_zero.{l_1} A) => A) (fun (zero : A) => zero) c

def has_zero.rec_on.{l, l_1} : (A : Type l_1) → (C : has_zero.{l_1} A → Type l) → (n : has_zero.{l_1} A) → ((zero : A) → C (has_zero.mk.{l_1} A zero)) → C n :=
  fun (A : Type l_1) => fun (C : has_zero.{l_1} A → Type l) => fun (n : has_zero.{l_1} A) => fun (e_1 : (zero : A) → C (has_zero.mk.{l_1} A zero)) => has_zero.rec.{l, l_1} A C e_1 n

