  fun (A : Type l_1) => fun (C : has_zero.{l_1} A → Type l) => fun (n : has_zero.{l_1} A) => fun (e_1 : (zero : A) → C (has_zero.mk.{l_1} A zero)) => has_zero.rec.{l, l_1} A C e_1 n

def has_zero.cases_on.{l, l_1} : (A : Type l_1) → (C : has_zero.{l_1} A → Type l) → (n : has_zero.{l_1} A) → ((zero : A) → C (has_zero.mk.{l_1} A zero)) → C n :=
  fun (A : Type l_1) => fun (C : has_zero.{l_1} A → Type l) => fun (n : has_zero.{l_1} A) => fun (e_1 : (zero : A) → C (has_zero.mk.{l_1} A zero)) => has_zero.rec.{l, l_1} A C e_1 n

def has_zero.no_confusion_type.{l, l_1} : (A : Type l_1) → Type l → has_zero.{l_1} A → has_zero.{l_1} A → Type (max l l_1) :=
  fun (A : Type l_1) => fun (P : Type l) => fun (v1 : has_zero.{l_1} A) => fun (v2 : has_zero.{l_1} A) => has_zero.cases_on.{max l l_1 + 1, l_1} A (fun (v1_1 : has_zero.{l_1} A) => Type (max l l_1)) v1 (fun (zero : A) => has_zero.cases_on.{max l l_1 + 1, l_1} A (fun (v1_1 : has_zero.{l_1} A) => Type (max l l_1)) v2 (fun (zero_1 : A) => (eq.{l_1} A zero zero_1 → P) → lift.{l, l_1} P))

def has_zero.no_confusion.{l, l_1} : (A : Type l_1) → (P : Type l) → (v1 : has_zero.{l_1} A) → (v2 : has_zero.{l_1} A) → eq.{l_1} (has_zero.{l_1} A) v1 v2 → has_zero.no_confusion_type.{l, l_1} A P v1 v2 :=
  fun (A : Type l_1) => fun (P : Type l) => fun (v1 : has_zero.{l_1} A) => fun (v2 : has_zero.{l_1} A) => fun (H12 : eq.{l_1} (has_zero.{l_1} A) v1 v2) => eq.rec.{max l l_1, l_1} (has_zero.{l_1} A) v1 (fun (a : has_zero.{l_1} A) => fun (H1a : eq.{l_1} (has_zero.{l_1} A) v1 a) => has_zero.no_confusion_type.{l, l_1} A P v1 a) (has_zero.cases_on.{max l l_1, l_1} A (fun (v1_1 : has_zero.{l_1} A) => has_zero.no_confusion_type.{l, l_1} A P v1_1 v1_1) v1 (fun (zero : A) => fun (a : eq.{l_1} A zero zero → P) => lift.up.{l, l_1} P (a (eq.refl.{l_1} A zero)))) v2 H12

