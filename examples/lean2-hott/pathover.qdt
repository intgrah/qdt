inductive eq.pathover.{l_1, l} (A : Type l_1) (a : A) (B : A â†’ Type l) (b : B a) : (aâ‚‚ : A) â†’ eq.{l_1} A a aâ‚‚ â†’ B aâ‚‚ â†’ Type l where
  | idpatho : eq.pathover.{l_1, l} A a B b a (eq.refl.{l_1} A a) b

def eq.pathover.rec_on.{l_2, l_1, l} : (A : Type l_1) â†’ (a : A) â†’ (B : A â†’ Type l) â†’ (b : B a) â†’ (C : (aâ‚‚ : A) â†’ (a_1 : eq.{l_1} A a aâ‚‚) â†’ (a_2 : B aâ‚‚) â†’ eq.pathover.{l_1, l} A a B b aâ‚‚ a_1 a_2 â†’ Type l_2) â†’ (aâ‚‚ : A) â†’ (a_1 : eq.{l_1} A a aâ‚‚) â†’ (a_2 : B aâ‚‚) â†’ (n : eq.pathover.{l_1, l} A a B b aâ‚‚ a_1 a_2) â†’ C a (eq.refl.{l_1} A a) b (eq.pathover.idpatho.{l_1, l} A a B b) â†’ C aâ‚‚ a_1 a_2 n :=
  fun (A : Type l_1) => fun (a : A) => fun (B : A â†’ Type l) => fun (b : B a) => fun (C : (aâ‚‚ : A) â†’ (a_1 : eq.{l_1} A a aâ‚‚) â†’ (a_2 : B aâ‚‚) â†’ eq.pathover.{l_1, l} A a B b aâ‚‚ a_1 a_2 â†’ Type l_2) => fun (aâ‚‚ : A) => fun (a_1 : eq.{l_1} A a aâ‚‚) => fun (a_2 : B aâ‚‚) => fun (n : eq.pathover.{l_1, l} A a B b aâ‚‚ a_1 a_2) => fun (e_1 : C a (eq.refl.{l_1} A a) b (eq.pathover.idpatho.{l_1, l} A a B b)) => eq.pathover.rec.{l_2, l_1, l} A a B b C e_1 aâ‚‚ a_1 a_2 n

def eq.pathover.cases_on.{l_2, l_1, l} : (A : Type l_1) â†’ (a : A) â†’ (B : A â†’ Type l) â†’ (b : B a) â†’ (C : (aâ‚‚ : A) â†’ (a_1 : eq.{l_1} A a aâ‚‚) â†’ (a_2 : B aâ‚‚) â†’ eq.pathover.{l_1, l} A a B b aâ‚‚ a_1 a_2 â†’ Type l_2) â†’ (aâ‚‚ : A) â†’ (a_1 : eq.{l_1} A a aâ‚‚) â†’ (a_2 : B aâ‚‚) â†’ (n : eq.pathover.{l_1, l} A a B b aâ‚‚ a_1 a_2) â†’ C a (eq.refl.{l_1} A a) b (eq.pathover.idpatho.{l_1, l} A a B b) â†’ C aâ‚‚ a_1 a_2 n :=
  fun (A : Type l_1) => fun (a : A) => fun (B : A â†’ Type l) => fun (b : B a) => fun (C : (aâ‚‚ : A) â†’ (a_1 : eq.{l_1} A a aâ‚‚) â†’ (a_2 : B aâ‚‚) â†’ eq.pathover.{l_1, l} A a B b aâ‚‚ a_1 a_2 â†’ Type l_2) => fun (aâ‚‚ : A) => fun (a_1 : eq.{l_1} A a aâ‚‚) => fun (a_2 : B aâ‚‚) => fun (n : eq.pathover.{l_1, l} A a B b aâ‚‚ a_1 a_2) => fun (e_1 : C a (eq.refl.{l_1} A a) b (eq.pathover.idpatho.{l_1, l} A a B b)) => eq.pathover.rec.{l_2, l_1, l} A a B b C e_1 aâ‚‚ a_1 a_2 n

def eq.pathover.no_confusion_type.{l_2, l_1, l} : (A : Type l_1) â†’ (a : A) â†’ (B : A â†’ Type l) â†’ (b : B a) â†’ (aâ‚‚ : A) â†’ (a_1 : eq.{l_1} A a aâ‚‚) â†’ (a_2 : B aâ‚‚) â†’ Type l_2 â†’ eq.pathover.{l_1, l} A a B b aâ‚‚ a_1 a_2 â†’ eq.pathover.{l_1, l} A a B b aâ‚‚ a_1 a_2 â†’ Type (max l_2 l) :=
  fun (A : Type l_1) => fun (a : A) => fun (B : A â†’ Type l) => fun (b : B a) => fun (aâ‚‚ : A) => fun (a_1 : eq.{l_1} A a aâ‚‚) => fun (a_2 : B aâ‚‚) => fun (P : Type l_2) => fun (v1 : eq.pathover.{l_1, l} A a B b aâ‚‚ a_1 a_2) => fun (v2 : eq.pathover.{l_1, l} A a B b aâ‚‚ a_1 a_2) => eq.pathover.cases_on.{max l_2 l + 1, l_1, l} A a B b (fun (aâ‚‚_1 : A) => fun (a_3 : eq.{l_1} A a aâ‚‚_1) => fun (a_4 : B aâ‚‚_1) => fun (v1_1 : eq.pathover.{l_1, l} A a B b aâ‚‚_1 a_3 a_4) => Type (max l_2 l)) aâ‚‚ a_1 a_2 v1 (eq.pathover.cases_on.{max l_2 l + 1, l_1, l} A a B b (fun (aâ‚‚_1 : A) => fun (a_3 : eq.{l_1} A a aâ‚‚_1) => fun (a_4 : B aâ‚‚_1) => fun (v1_1 : eq.pathover.{l_1, l} A a B b aâ‚‚_1 a_3 a_4) => Type (max l_2 l)) aâ‚‚ a_1 a_2 v2 (P â†’ lift.{l_2, l} P))

def eq.pathover.no_confusion.{l_2, l_1, l} : (A : Type l_1) â†’ (a : A) â†’ (B : A â†’ Type l) â†’ (b : B a) â†’ (aâ‚‚ : A) â†’ (a_1 : eq.{l_1} A a aâ‚‚) â†’ (a_2 : B aâ‚‚) â†’ (P : Type l_2) â†’ (v1 : eq.pathover.{l_1, l} A a B b aâ‚‚ a_1 a_2) â†’ (v2 : eq.pathover.{l_1, l} A a B b aâ‚‚ a_1 a_2) â†’ eq.{l} (eq.pathover.{l_1, l} A a B b aâ‚‚ a_1 a_2) v1 v2 â†’ eq.pathover.no_confusion_type.{l_2, l_1, l} A a B b aâ‚‚ a_1 a_2 P v1 v2 :=
  fun (A : Type l_1) => fun (a : A) => fun (B : A â†’ Type l) => fun (b : B a) => fun (aâ‚‚ : A) => fun (a_1 : eq.{l_1} A a aâ‚‚) => fun (a_2 : B aâ‚‚) => fun (P : Type l_2) => fun (v1 : eq.pathover.{l_1, l} A a B b aâ‚‚ a_1 a_2) => fun (v2 : eq.pathover.{l_1, l} A a B b aâ‚‚ a_1 a_2) => fun (H12 : eq.{l} (eq.pathover.{l_1, l} A a B b aâ‚‚ a_1 a_2) v1 v2) => eq.rec.{max l_2 l, l} (eq.pathover.{l_1, l} A a B b aâ‚‚ a_1 a_2) v1 (fun (a_3 : eq.pathover.{l_1, l} A a B b aâ‚‚ a_1 a_2) => fun (H1a : eq.{l} (eq.pathover.{l_1, l} A a B b aâ‚‚ a_1 a_2) v1 a_3) => eq.pathover.no_confusion_type.{l_2, l_1, l} A a B b aâ‚‚ a_1 a_2 P v1 a_3) (eq.pathover.cases_on.{max l_2 l, l_1, l} A a B b (fun (aâ‚‚_1 : A) => fun (a_3 : eq.{l_1} A a aâ‚‚_1) => fun (a_4 : B aâ‚‚_1) => fun (v1_1 : eq.pathover.{l_1, l} A a B b aâ‚‚_1 a_3 a_4) => eq.pathover.no_confusion_type.{l_2, l_1, l} A a B b aâ‚‚_1 a_3 a_4 P v1_1 v1_1) aâ‚‚ a_1 a_2 v1 (fun (a_3 : P) => lift.up.{l_2, l} P a_3)) v2 H12

def eq.idpo.{l_1, l_3} : (A : Type l_1) â†’ (B : A â†’ Type l_3) â†’ (a : A) â†’ (b : B a) â†’ eq.pathover.{l_1, l_3} A a B b a (eq.refl.{l_1} A a) b :=
