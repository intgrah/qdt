def eq.pathover_of_tr_eq.{l_1, l_3} : (A : Type l_1) â†’ (B : A â†’ Type l_3) â†’ (a : A) â†’ (aâ‚‚ : A) â†’ (p : eq.{l_1} A a aâ‚‚) â†’ (b : B a) â†’ (bâ‚‚ : B aâ‚‚) â†’ eq.{l_3} (B aâ‚‚) (eq.transport.{l_1, l_3} A B a aâ‚‚ p b) bâ‚‚ â†’ eq.pathover.{l_1, l_3} A a B b aâ‚‚ p bâ‚‚ :=
