def eq.idpatho.{l_1, l_3} : (A : Type l_1) â†’ (B : A â†’ Type l_3) â†’ (a : A) â†’ (b : B a) â†’ eq.pathover.{l_1, l_3} A a B b a (eq.refl.{l_1} A a) b :=
