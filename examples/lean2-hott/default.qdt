def core.ap10.{l_1, l_3} : (A : Type l_1) → (B : Type l_3) → (f : A → B) → (g : A → B) → eq.{max l_1 l_3} (A → B) f g → eq.homotopy.{l_1, l_3} A (fun (x : A) => B) f g :=
  eq.ap10.{l_1, l_3}

