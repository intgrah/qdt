def core.to_right_inv.{l_1, l_2} : (A : Type l_1) → (B : Type l_2) → (f : equiv.{l_1, l_2} A B) → (b : B) → eq.{l_2} B (equiv.to_fun.{l_1, l_2} A B f (is_equiv.inv.{l_1, l_2} A B (equiv.to_fun.{l_1, l_2} A B f) (equiv.to_is_equiv.{l_1, l_2} A B f) b)) b :=
  equiv.to_right_inv.{l_1, l_2}

def core.to_left_inv.{l_1, l_2} : (A : Type l_1) → (B : Type l_2) → (f : equiv.{l_1, l_2} A B) → (a : A) → eq.{l_1} A (is_equiv.inv.{l_1, l_2} A B (equiv.to_fun.{l_1, l_2} A B f) (equiv.to_is_equiv.{l_1, l_2} A B f) (equiv.to_fun.{l_1, l_2} A B f a)) a :=
  equiv.to_left_inv.{l_1, l_2}

def core.inv.{l_1, l_2} : (A : Type l_1) → (B : Type l_2) → (f : A → B) → is_equiv.{l_1, l_2} A B f → B → A :=
  is_equiv.inv.{l_1, l_2}

def core.right_inv.{l_1, l_2} : (A : Type l_1) → (B : Type l_2) → (f : A → B) → (c : is_equiv.{l_1, l_2} A B f) → (b : B) → eq.{l_2} B (f (is_equiv.inv.{l_1, l_2} A B f c b)) b :=
  is_equiv.right_inv.{l_1, l_2}

def core.left_inv.{l_1, l_2} : (A : Type l_1) → (B : Type l_2) → (f : A → B) → (c : is_equiv.{l_1, l_2} A B f) → (a : A) → eq.{l_1} A (is_equiv.inv.{l_1, l_2} A B f c (f a)) a :=
  is_equiv.left_inv.{l_1, l_2}

def core.adjointify.{l_1, l_2} : (A : Type l_1) → (B : Type l_2) → (f : A → B) → (g : B → A) → ((b : B) → eq.{l_2} B (f (g b)) b) → ((a : A) → eq.{l_1} A (g (f a)) a) → is_equiv.{l_1, l_2} A B f :=
  is_equiv.adjointify.{l_1, l_2}

