import trunc

inductive pointed.{l_1} (A : Type l_1) : Type l_1 where
  | mk : A → pointed.{l_1} A

def pointed.point.{l_1} : (A : Type l_1) → pointed.{l_1} A → A :=
  fun (A : Type l_1) => fun (c : pointed.{l_1} A) => pointed.rec.{l_1, l_1} A (fun (c_1 : pointed.{l_1} A) => A) (fun (point : A) => point) c

def pointed.rec_on.{l, l_1} : (A : Type l_1) → (C : pointed.{l_1} A → Type l) → (n : pointed.{l_1} A) → ((point : A) → C (pointed.mk.{l_1} A point)) → C n :=
  fun (A : Type l_1) => fun (C : pointed.{l_1} A → Type l) => fun (n : pointed.{l_1} A) => fun (e_1 : (point : A) → C (pointed.mk.{l_1} A point)) => pointed.rec.{l, l_1} A C e_1 n

def pointed.destruct.{l, l_1} : (A : Type l_1) → (C : pointed.{l_1} A → Type l) → (n : pointed.{l_1} A) → ((point : A) → C (pointed.mk.{l_1} A point)) → C n :=
  fun (A : Type l_1) => fun (C : pointed.{l_1} A → Type l) => fun (n : pointed.{l_1} A) => fun (e_1 : (point : A) → C (pointed.mk.{l_1} A point)) => pointed.rec.{l, l_1} A C e_1 n

def pointed.cases_on.{l, l_1} : (A : Type l_1) → (C : pointed.{l_1} A → Type l) → (n : pointed.{l_1} A) → ((point : A) → C (pointed.mk.{l_1} A point)) → C n :=
  fun (A : Type l_1) => fun (C : pointed.{l_1} A → Type l) => fun (n : pointed.{l_1} A) => fun (e_1 : (point : A) → C (pointed.mk.{l_1} A point)) => pointed.rec.{l, l_1} A C e_1 n

def pointed.no_confusion_type.{l, l_1} : (A : Type l_1) → Type l → pointed.{l_1} A → pointed.{l_1} A → Type (max l l_1) :=
  fun (A : Type l_1) => fun (P : Type l) => fun (v1 : pointed.{l_1} A) => fun (v2 : pointed.{l_1} A) => pointed.cases_on.{max l l_1 + 1, l_1} A (fun (v1_1 : pointed.{l_1} A) => Type (max l l_1)) v1 (fun (point : A) => pointed.cases_on.{max l l_1 + 1, l_1} A (fun (v1_1 : pointed.{l_1} A) => Type (max l l_1)) v2 (fun (point_1 : A) => (eq.{l_1} A point point_1 → P) → lift.{l, l_1} P))

def pointed.no_confusion.{l, l_1} : (A : Type l_1) → (P : Type l) → (v1 : pointed.{l_1} A) → (v2 : pointed.{l_1} A) → eq.{l_1} (pointed.{l_1} A) v1 v2 → pointed.no_confusion_type.{l, l_1} A P v1 v2 :=
  fun (A : Type l_1) => fun (P : Type l) => fun (v1 : pointed.{l_1} A) => fun (v2 : pointed.{l_1} A) => fun (H12 : eq.{l_1} (pointed.{l_1} A) v1 v2) => eq.rec.{max l l_1, l_1} (pointed.{l_1} A) v1 (fun (a : pointed.{l_1} A) => fun (H1a : eq.{l_1} (pointed.{l_1} A) v1 a) => pointed.no_confusion_type.{l, l_1} A P v1 a) (pointed.cases_on.{max l l_1, l_1} A (fun (v1_1 : pointed.{l_1} A) => pointed.no_confusion_type.{l, l_1} A P v1_1 v1_1) v1 (fun (point : A) => fun (a : eq.{l_1} A point point → P) => lift.up.{l, l_1} P (a (eq.refl.{l_1} A point)))) v2 H12

inductive pType.{l_1} : Type (l_1 + 1) where
  | mk : (carrier : Type l_1) → carrier → pType.{l_1}

def pType.carrier.{l_1} : pType.{l_1} → Type l_1 :=
  fun (c : pType.{l_1}) => pType.rec.{l_1 + 1, l_1} (fun (c_1 : pType.{l_1}) => Type l_1) (fun (carrier : Type l_1) => fun (Point : carrier) => carrier) c

def pType.Point.{l_1} : (c : pType.{l_1}) → pType.carrier.{l_1} c :=
  fun (c : pType.{l_1}) => pType.rec.{l_1, l_1} (fun (c_1 : pType.{l_1}) => pType.carrier.{l_1} c_1) (fun (carrier : Type l_1) => fun (Point : carrier) => Point) c

def pType.rec_on.{l, l_1} : (C : pType.{l_1} → Type l) → (n : pType.{l_1}) → ((carrier : Type l_1) → (Point : carrier) → C (pType.mk.{l_1} carrier Point)) → C n :=
  fun (C : pType.{l_1} → Type l) => fun (n : pType.{l_1}) => fun (e_1 : (carrier : Type l_1) → (Point : carrier) → C (pType.mk.{l_1} carrier Point)) => pType.rec.{l, l_1} C e_1 n

def pType.destruct.{l, l_1} : (C : pType.{l_1} → Type l) → (n : pType.{l_1}) → ((carrier : Type l_1) → (Point : carrier) → C (pType.mk.{l_1} carrier Point)) → C n :=
  fun (C : pType.{l_1} → Type l) => fun (n : pType.{l_1}) => fun (e_1 : (carrier : Type l_1) → (Point : carrier) → C (pType.mk.{l_1} carrier Point)) => pType.rec.{l, l_1} C e_1 n

def pType.cases_on.{l, l_1} : (C : pType.{l_1} → Type l) → (n : pType.{l_1}) → ((carrier : Type l_1) → (Point : carrier) → C (pType.mk.{l_1} carrier Point)) → C n :=
  fun (C : pType.{l_1} → Type l) => fun (n : pType.{l_1}) => fun (e_1 : (carrier : Type l_1) → (Point : carrier) → C (pType.mk.{l_1} carrier Point)) => pType.rec.{l, l_1} C e_1 n

def pType.no_confusion_type.{l, l_1} : Type l → pType.{l_1} → pType.{l_1} → Type (max l (l_1 + 1)) :=
  fun (P : Type l) => fun (v1 : pType.{l_1}) => fun (v2 : pType.{l_1}) => pType.cases_on.{max l (l_1 + 1) + 1, l_1} (fun (v1_1 : pType.{l_1}) => Type (max l (l_1 + 1))) v1 (fun (carrier : Type l_1) => fun (Point : carrier) => pType.cases_on.{max l (l_1 + 1) + 1, l_1} (fun (v1_1 : pType.{l_1}) => Type (max l (l_1 + 1))) v2 (fun (carrier_1 : Type l_1) => fun (Point_1 : carrier_1) => ((e_1 : eq.{l_1 + 1} Type l_1 carrier carrier_1) → eq.{l_1} carrier_1 (eq.rec.{l_1, l_1 + 1} Type l_1 carrier (fun (carrier_2 : Type l_1) => fun (e_1_1 : eq.{l_1 + 1} Type l_1 carrier carrier_2) => carrier_2) Point carrier_1 e_1) Point_1 → P) → lift.{l, l_1 + 1} P))

def pType.no_confusion.{l, l_1} : (P : Type l) → (v1 : pType.{l_1}) → (v2 : pType.{l_1}) → eq.{l_1 + 1} pType.{l_1} v1 v2 → pType.no_confusion_type.{l, l_1} P v1 v2 :=
  fun (P : Type l) => fun (v1 : pType.{l_1}) => fun (v2 : pType.{l_1}) => fun (H12 : eq.{l_1 + 1} pType.{l_1} v1 v2) => eq.rec.{max l (l_1 + 1), l_1 + 1} pType.{l_1} v1 (fun (a : pType.{l_1}) => fun (H1a : eq.{l_1 + 1} pType.{l_1} v1 a) => pType.no_confusion_type.{l, l_1} P v1 a) (pType.cases_on.{max l (l_1 + 1), l_1} (fun (v1_1 : pType.{l_1}) => pType.no_confusion_type.{l, l_1} P v1_1 v1_1) v1 (fun (carrier : Type l_1) => fun (Point : carrier) => fun (a : (e_1 : eq.{l_1 + 1} Type l_1 carrier carrier) → eq.{l_1} carrier (eq.rec.{l_1, l_1 + 1} Type l_1 carrier (fun (carrier_1 : Type l_1) => fun (e_1_1 : eq.{l_1 + 1} Type l_1 carrier carrier_1) => carrier_1) Point carrier e_1) Point → P) => lift.up.{l, l_1 + 1} P (a (eq.refl.{l_1 + 1} Type l_1 carrier) (eq.refl.{l_1} carrier Point)))) v2 H12

def pointed.pt.{l_1} : (A : Type l_1) → pointed.{l_1} A → A :=
  pointed.point.{l_1}

def pointed.Point.{l_2} : (A : pType.{l_2}) → pType.carrier.{l_2} A :=
  pType.Point.{l_2}

def pointed.carrier.{l_2} : pType.{l_2} → Type l_2 :=
  pType.carrier.{l_2}

def pointed.Mk.{l_2} : (A : Type l_2) → A → pType.{l_2} :=
  pType.mk.{l_2}

def pointed.MK.{l_2} : (A : Type l_2) → A → pType.{l_2} :=
  pType.mk.{l_2}

def pointed.mk'.{l_2} : (A : Type l_2) → pointed.{l_2} A → pType.{l_2} :=
  fun (A : Type l_2) => fun (H : pointed.{l_2} A) => pType.mk.{l_2} A (pointed.point.{l_2} A H)

def pointed.pointed_carrier.{l_2} : (A : pType.{l_2}) → pointed.{l_2} (pType.carrier.{l_2} A) :=
  fun (A : pType.{l_2}) => pointed.mk.{l_2} (pType.carrier.{l_2} A) (pointed.Point.{l_2} A)

inductive ptrunctype.{u} (n : trunc_index) : Type (u + 1) where
  | mk : (carrier : Type u) → is_trunc.{u} n carrier → carrier → ptrunctype.{u} n

def ptrunctype.carrier.{u} : (n : trunc_index) → ptrunctype.{u} n → Type u :=
  fun (n : trunc_index) => fun (c : ptrunctype.{u} n) => ptrunctype.rec.{u + 1, u} n (fun (c_1 : ptrunctype.{u} n) => Type u) (fun (carrier : Type u) => fun (struct : is_trunc.{u} n carrier) => fun (Point : carrier) => carrier) c

def ptrunctype.struct.{u} : (n : trunc_index) → (c : ptrunctype.{u} n) → is_trunc.{u} n (ptrunctype.carrier.{u} n c) :=
  fun (n : trunc_index) => fun (c : ptrunctype.{u} n) => ptrunctype.rec.{u, u} n (fun (c_1 : ptrunctype.{u} n) => is_trunc.{u} n (ptrunctype.carrier.{u} n c_1)) (fun (carrier : Type u) => fun (struct : is_trunc.{u} n carrier) => fun (Point : carrier) => struct) c

def ptrunctype.Point.{u} : (n : trunc_index) → (c : ptrunctype.{u} n) → ptrunctype.carrier.{u} n c :=
  fun (n : trunc_index) => fun (c : ptrunctype.{u} n) => ptrunctype.rec.{u, u} n (fun (c_1 : ptrunctype.{u} n) => ptrunctype.carrier.{u} n c_1) (fun (carrier : Type u) => fun (struct : is_trunc.{u} n carrier) => fun (Point : carrier) => Point) c

def ptrunctype.rec_on.{l, u} : (n : trunc_index) → (C : ptrunctype.{u} n → Type l) → (n_1 : ptrunctype.{u} n) → ((carrier : Type u) → (struct : is_trunc.{u} n carrier) → (Point : carrier) → C (ptrunctype.mk.{u} n carrier struct Point)) → C n_1 :=
  fun (n : trunc_index) => fun (C : ptrunctype.{u} n → Type l) => fun (n_1 : ptrunctype.{u} n) => fun (e_1 : (carrier : Type u) → (struct : is_trunc.{u} n carrier) → (Point : carrier) → C (ptrunctype.mk.{u} n carrier struct Point)) => ptrunctype.rec.{l, u} n C e_1 n_1

def ptrunctype.destruct.{l, u} : (n : trunc_index) → (C : ptrunctype.{u} n → Type l) → (n_1 : ptrunctype.{u} n) → ((carrier : Type u) → (struct : is_trunc.{u} n carrier) → (Point : carrier) → C (ptrunctype.mk.{u} n carrier struct Point)) → C n_1 :=
  fun (n : trunc_index) => fun (C : ptrunctype.{u} n → Type l) => fun (n_1 : ptrunctype.{u} n) => fun (e_1 : (carrier : Type u) → (struct : is_trunc.{u} n carrier) → (Point : carrier) → C (ptrunctype.mk.{u} n carrier struct Point)) => ptrunctype.rec.{l, u} n C e_1 n_1

def ptrunctype.cases_on.{l, u} : (n : trunc_index) → (C : ptrunctype.{u} n → Type l) → (n_1 : ptrunctype.{u} n) → ((carrier : Type u) → (struct : is_trunc.{u} n carrier) → (Point : carrier) → C (ptrunctype.mk.{u} n carrier struct Point)) → C n_1 :=
  fun (n : trunc_index) => fun (C : ptrunctype.{u} n → Type l) => fun (n_1 : ptrunctype.{u} n) => fun (e_1 : (carrier : Type u) → (struct : is_trunc.{u} n carrier) → (Point : carrier) → C (ptrunctype.mk.{u} n carrier struct Point)) => ptrunctype.rec.{l, u} n C e_1 n_1

def ptrunctype.to_trunctype.{u} : (n : trunc_index) → ptrunctype.{u} n → trunctype.{u} n :=
  fun (n : trunc_index) => fun (s : ptrunctype.{u} n) => trunctype.mk.{u} n (ptrunctype.carrier.{u} n s) (ptrunctype.struct.{u} n s)

def ptrunctype._trans_of_to_trunctype.{u} : (n : trunc_index) → ptrunctype.{u} n → Type u :=
  fun (n : trunc_index) => fun (s : ptrunctype.{u} n) => trunctype.carrier.{u} n (ptrunctype.to_trunctype.{u} n s)

def ptrunctype.to_pType.{u} : (n : trunc_index) → ptrunctype.{u} n → pType.{u} :=
  fun (n : trunc_index) => fun (s : ptrunctype.{u} n) => pType.mk.{u} (ptrunctype.carrier.{u} n s) (ptrunctype.Point.{u} n s)

def ptrunctype._trans_of_to_pType.{u} : (n : trunc_index) → ptrunctype.{u} n → Type u :=
  fun (n : trunc_index) => fun (s : ptrunctype.{u} n) => pType.carrier.{u} (ptrunctype.to_pType.{u} n s)

def ptrunctype.no_confusion_type.{l, u} : (n : trunc_index) → Type l → ptrunctype.{u} n → ptrunctype.{u} n → Type (max l (u + 1)) :=
  fun (n : trunc_index) => fun (P : Type l) => fun (v1 : ptrunctype.{u} n) => fun (v2 : ptrunctype.{u} n) => ptrunctype.cases_on.{max l (u + 1) + 1, u} n (fun (v1_1 : ptrunctype.{u} n) => Type (max l (u + 1))) v1 (fun (carrier : Type u) => fun (struct : is_trunc.{u} n carrier) => fun (Point : carrier) => ptrunctype.cases_on.{max l (u + 1) + 1, u} n (fun (v1_1 : ptrunctype.{u} n) => Type (max l (u + 1))) v2 (fun (carrier_1 : Type u) => fun (struct_1 : is_trunc.{u} n carrier_1) => fun (Point_1 : carrier_1) => ((e_1 : eq.{u + 1} Type u carrier carrier_1) → eq.{u} (is_trunc.{u} n carrier_1) (eq.rec.{u, u + 1} Type u carrier (fun (carrier_2 : Type u) => fun (e_1_1 : eq.{u + 1} Type u carrier carrier_2) => is_trunc.{u} n carrier_2) struct carrier_1 e_1) struct_1 → eq.{u} carrier_1 (eq.rec.{u, u + 1} Type u carrier (fun (carrier_2 : Type u) => fun (e_1_1 : eq.{u + 1} Type u carrier carrier_2) => carrier_2) Point carrier_1 e_1) Point_1 → P) → lift.{l, u + 1} P))

def ptrunctype.no_confusion.{l, u} : (n : trunc_index) → (P : Type l) → (v1 : ptrunctype.{u} n) → (v2 : ptrunctype.{u} n) → eq.{u + 1} (ptrunctype.{u} n) v1 v2 → ptrunctype.no_confusion_type.{l, u} n P v1 v2 :=
  fun (n : trunc_index) => fun (P : Type l) => fun (v1 : ptrunctype.{u} n) => fun (v2 : ptrunctype.{u} n) => fun (H12 : eq.{u + 1} (ptrunctype.{u} n) v1 v2) => eq.rec.{max l (u + 1), u + 1} (ptrunctype.{u} n) v1 (fun (a : ptrunctype.{u} n) => fun (H1a : eq.{u + 1} (ptrunctype.{u} n) v1 a) => ptrunctype.no_confusion_type.{l, u} n P v1 a) (ptrunctype.cases_on.{max l (u + 1), u} n (fun (v1_1 : ptrunctype.{u} n) => ptrunctype.no_confusion_type.{l, u} n P v1_1 v1_1) v1 (fun (carrier : Type u) => fun (struct : is_trunc.{u} n carrier) => fun (Point : carrier) => fun (a : (e_1 : eq.{u + 1} Type u carrier carrier) → eq.{u} (is_trunc.{u} n carrier) (eq.rec.{u, u + 1} Type u carrier (fun (carrier_1 : Type u) => fun (e_1_1 : eq.{u + 1} Type u carrier carrier_1) => is_trunc.{u} n carrier_1) struct carrier e_1) struct → eq.{u} carrier (eq.rec.{u, u + 1} Type u carrier (fun (carrier_1 : Type u) => fun (e_1_1 : eq.{u + 1} Type u carrier carrier_1) => carrier_1) Point carrier e_1) Point → P) => lift.up.{l, u + 1} P (a (eq.refl.{u + 1} Type u carrier) (eq.refl.{u} (is_trunc.{u} n carrier) struct) (eq.refl.{u} carrier Point)))) v2 H12

def is_trunc_ptrunctype.{l_1} : (n : trunc_index) → (X : ptrunctype.{l_1} n) → is_trunc.{l_1} n (pType.carrier.{l_1} (ptrunctype.to_pType.{l_1} n X)) :=
  fun (n : trunc_index) => fun (X : ptrunctype.{l_1} n) => trunctype.struct.{l_1} n (ptrunctype.to_trunctype.{l_1} n X)

def pSet.{l_1} : Type (l_1 + 1) :=
  ptrunctype.{l_1} (zero.{0} trunc_index has_zero_trunc_index)

def pointed.ptrunctype.mk'.{l_1} : (n : trunc_index) → (A : Type l_1) → pointed.{l_1} A → is_trunc.{l_1} n A → ptrunctype.{l_1} n :=
  fun (n : trunc_index) => fun (A : Type l_1) => fun (_inst_1 : pointed.{l_1} A) => fun (_inst_2 : is_trunc.{l_1} n A) => ptrunctype.mk.{l_1} n A _inst_2 (pointed.pt.{l_1} A _inst_1)

def pointed.pSet.mk.{l_1} : (carrier : Type l_1) → is_trunc.{l_1} (trunc_index.succ (trunc_index.succ trunc_index.minus_two)) carrier → carrier → ptrunctype.{l_1} (trunc_index.succ (trunc_index.succ trunc_index.minus_two)) :=
  ptrunctype.mk.{l_1} (trunc_index.succ (trunc_index.succ trunc_index.minus_two))

def pointed.pSet.mk'.{l_1} : (A : Type l_1) → pointed.{l_1} A → is_trunc.{l_1} (trunc_index.succ (trunc_index.succ trunc_index.minus_two)) A → ptrunctype.{l_1} (trunc_index.succ (trunc_index.succ trunc_index.minus_two)) :=
  pointed.ptrunctype.mk'.{l_1} (trunc_index.succ (trunc_index.succ trunc_index.minus_two))

def pointed.ptrunctype_of_trunctype.{l_1} : (n : trunc_index) → (A : trunctype.{l_1} n) → trunctype.carrier.{l_1} n A → ptrunctype.{l_1} n :=
