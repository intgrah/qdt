def pointed.pSet_of_Set.{l_1} : (A : trunctype.{l_1} (zero.{0} trunc_index has_zero_trunc_index)) → trunctype.carrier.{l_1} (zero.{0} trunc_index has_zero_trunc_index) A → ptrunctype.{l_1} (zero.{0} trunc_index has_zero_trunc_index) :=
