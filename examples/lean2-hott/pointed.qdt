def pointed.pointed_of_is_contr.{l_1} : (A : Type l_1) → is_trunc.{l_1} trunc_index.minus_two A → pointed.{l_1} A :=
  fun (A : Type l_1) => fun (H : is_trunc.{l_1} trunc_index.minus_two A) => pointed.mk.{l_1} A (is_trunc.center.{l_1} A H)

inductive ppi.{l_1, l_2} (A : pType.{l_1}) (P : pType.carrier.{l_1} A → Type l_2) (x₀ : P (pointed.pt.{l_1} (pType.carrier.{l_1} A) (pointed.pointed_carrier.{l_1} A))) : Type (max l_1 l_2) where
