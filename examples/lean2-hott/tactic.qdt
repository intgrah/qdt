def tactic.trivial : tactic :=
  tactic.or_else (tactic.apply tactic.expr.builtin) tactic.assumption

def tactic.do : nat → tactic → tactic :=
  fun (n : nat) => fun (t : tactic) => nat.rec.{0} (fun (a : nat) => tactic) tactic.id (fun (n_1 : nat) => tactic.and_then t) n

