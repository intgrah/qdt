inductive tactic : Type 0 where
  | builtin : tactic

def tactic.rec_on.{l} : (C : tactic → Type l) → (n : tactic) → C tactic.builtin → C n :=
  fun (C : tactic → Type l) => fun (n : tactic) => fun (e_1 : C tactic.builtin) => tactic.rec.{l} C e_1 n

def tactic.cases_on.{l} : (C : tactic → Type l) → (n : tactic) → C tactic.builtin → C n :=
  fun (C : tactic → Type l) => fun (n : tactic) => fun (e_1 : C tactic.builtin) => tactic.rec.{l} C e_1 n

def tactic.no_confusion_type.{l} : Type l → tactic → tactic → Type l :=
  fun (P : Type l) => fun (v1 : tactic) => fun (v2 : tactic) => tactic.cases_on.{l + 1} (fun (v1_1 : tactic) => Type l) v1 (tactic.cases_on.{l + 1} (fun (v1_1 : tactic) => Type l) v2 (P → lift.{l, 0} P))

def tactic.no_confusion.{l} : (P : Type l) → (v1 : tactic) → (v2 : tactic) → eq.{0} tactic v1 v2 → tactic.no_confusion_type.{l} P v1 v2 :=
  fun (P : Type l) => fun (v1 : tactic) => fun (v2 : tactic) => fun (H12 : eq.{0} tactic v1 v2) => eq.rec.{l, 0} tactic v1 (fun (a : tactic) => fun (H1a : eq.{0} tactic v1 a) => tactic.no_confusion_type.{l} P v1 a) (tactic.cases_on.{l} (fun (v1_1 : tactic) => tactic.no_confusion_type.{l} P v1_1 v1_1) v1 (fun (a : P) => lift.up.{l, 0} P a)) v2 H12

