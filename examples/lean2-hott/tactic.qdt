  fun (P : Type l) => fun (v1 : tactic.expr) => fun (v2 : tactic.expr) => tactic.expr.cases_on.{l + 1} (fun (v1_1 : tactic.expr) => Type l) v1 (tactic.expr.cases_on.{l + 1} (fun (v1_1 : tactic.expr) => Type l) v2 (P → lift.{l, 0} P))

def tactic.expr.no_confusion.{l} : (P : Type l) → (v1 : tactic.expr) → (v2 : tactic.expr) → eq.{0} tactic.expr v1 v2 → tactic.expr.no_confusion_type.{l} P v1 v2 :=
  fun (P : Type l) => fun (v1 : tactic.expr) => fun (v2 : tactic.expr) => fun (H12 : eq.{0} tactic.expr v1 v2) => eq.rec.{l, 0} tactic.expr v1 (fun (a : tactic.expr) => fun (H1a : eq.{0} tactic.expr v1 a) => tactic.expr.no_confusion_type.{l} P v1 a) (tactic.expr.cases_on.{l} (fun (v1_1 : tactic.expr) => tactic.expr.no_confusion_type.{l} P v1_1 v1_1) v1 (fun (a : P) => lift.up.{l, 0} P a)) v2 H12

inductive tactic.expr_list : Type 0 where
  | nil : tactic.expr_list
  | cons : tactic.expr → tactic.expr_list → tactic.expr_list

def tactic.expr_list.rec_on.{l} : (C : tactic.expr_list → Type l) → (n : tactic.expr_list) → C tactic.expr_list.nil → ((a : tactic.expr) → (a_1 : tactic.expr_list) → C a_1 → C (tactic.expr_list.cons a a_1)) → C n :=
  fun (C : tactic.expr_list → Type l) => fun (n : tactic.expr_list) => fun (e_1 : C tactic.expr_list.nil) => fun (e_2 : (a : tactic.expr) → (a_1 : tactic.expr_list) → C a_1 → C (tactic.expr_list.cons a a_1)) => tactic.expr_list.rec.{l} C e_1 e_2 n

def tactic.expr_list.cases_on.{l} : (C : tactic.expr_list → Type l) → (n : tactic.expr_list) → C tactic.expr_list.nil → ((a : tactic.expr) → (a_1 : tactic.expr_list) → C (tactic.expr_list.cons a a_1)) → C n :=
  fun (C : tactic.expr_list → Type l) => fun (n : tactic.expr_list) => fun (e_1 : C tactic.expr_list.nil) => fun (e_2 : (a : tactic.expr) → (a_1 : tactic.expr_list) → C (tactic.expr_list.cons a a_1)) => tactic.expr_list.rec.{l} C e_1 (fun (a : tactic.expr) => fun (a_1 : tactic.expr_list) => fun (v_0 : C a_1) => e_2 a a_1) n

def tactic.expr_list.no_confusion_type.{l} : Type l → tactic.expr_list → tactic.expr_list → Type l :=
  fun (P : Type l) => fun (v1 : tactic.expr_list) => fun (v2 : tactic.expr_list) => tactic.expr_list.cases_on.{l + 1} (fun (v1_1 : tactic.expr_list) => Type l) v1 (tactic.expr_list.cases_on.{l + 1} (fun (v1_1 : tactic.expr_list) => Type l) v2 (P → lift.{l, 0} P) (fun (a : tactic.expr) => fun (a_1 : tactic.expr_list) => lift.{l, 0} P)) (fun (a : tactic.expr) => fun (a_1 : tactic.expr_list) => tactic.expr_list.cases_on.{l + 1} (fun (v1_1 : tactic.expr_list) => Type l) v2 (lift.{l, 0} P) (fun (a_2 : tactic.expr) => fun (a_3 : tactic.expr_list) => (eq.{0} tactic.expr a a_2 → eq.{0} tactic.expr_list a_1 a_3 → P) → lift.{l, 0} P))

def tactic.expr_list.no_confusion.{l} : (P : Type l) → (v1 : tactic.expr_list) → (v2 : tactic.expr_list) → eq.{0} tactic.expr_list v1 v2 → tactic.expr_list.no_confusion_type.{l} P v1 v2 :=
  fun (P : Type l) => fun (v1 : tactic.expr_list) => fun (v2 : tactic.expr_list) => fun (H12 : eq.{0} tactic.expr_list v1 v2) => eq.rec.{l, 0} tactic.expr_list v1 (fun (a : tactic.expr_list) => fun (H1a : eq.{0} tactic.expr_list v1 a) => tactic.expr_list.no_confusion_type.{l} P v1 a) (tactic.expr_list.cases_on.{l} (fun (v1_1 : tactic.expr_list) => tactic.expr_list.no_confusion_type.{l} P v1_1 v1_1) v1 (fun (a : P) => lift.up.{l, 0} P a) (fun (a : tactic.expr) => fun (a_1 : tactic.expr_list) => fun (a_2 : eq.{0} tactic.expr a a → eq.{0} tactic.expr_list a_1 a_1 → P) => lift.up.{l, 0} P (a_2 (eq.refl.{0} tactic.expr a) (eq.refl.{0} tactic.expr_list a_1)))) v2 H12

def tactic.expr_list.below.{l} : (tactic.expr_list → Type l) → tactic.expr_list → Type (max (1) l) :=
  fun (C : tactic.expr_list → Type l) => fun (n : tactic.expr_list) => tactic.expr_list.rec.{max (1) l + 1} (fun (n_1 : tactic.expr_list) => Type (max (1) l)) poly_unit.{max (1) l} (fun (a : tactic.expr) => fun (a_1 : tactic.expr_list) => fun (v_0 : Type (max (1) l)) => prod.{l, max (1) l} (C a_1) v_0) n

def tactic.expr_list.brec_on.{l} : (C : tactic.expr_list → Type l) → (n : tactic.expr_list) → ((n_1 : tactic.expr_list) → tactic.expr_list.below.{l} C n_1 → C n_1) → C n :=
  fun (C : tactic.expr_list → Type l) => fun (n : tactic.expr_list) => fun (F_1 : (n_1 : tactic.expr_list) → tactic.expr_list.below.{l} C n_1 → C n_1) => prod.pr1.{l, max (1) l} (C n) (tactic.expr_list.below.{l} C n) (tactic.expr_list.rec.{max (1) l} (fun (n_1 : tactic.expr_list) => prod.{l, max (1) l} (C n_1) (tactic.expr_list.below.{l} C n_1)) (prod.mk.{l, max (1) l} (C tactic.expr_list.nil) poly_unit.{max (1) l} (F_1 tactic.expr_list.nil poly_unit.star.{max (1) l}) poly_unit.star.{max (1) l}) (fun (a : tactic.expr) => fun (a_1 : tactic.expr_list) => fun (v_0 : prod.{l, max (1) l} (C a_1) (tactic.expr_list.below.{l} C a_1)) => prod.mk.{l, max (1) l} (C (tactic.expr_list.cons a a_1)) (prod.{l, max (1) l} (C a_1) (tactic.expr_list.below.{l} C a_1)) (F_1 (tactic.expr_list.cons a a_1) v_0) v_0) n)

